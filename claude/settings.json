{
  "model": "sonnet",
  "theme": "light",
  "disableAutoMode": "disable",
  "env": {
    "ENABLE_TOOL_SEARCH": "auto"
  },

  "mcpServers": {},
  "permissions":{
    "deny": [
      "Artifact",
      "CronCreate",
      "CronDelete",
      "CronList",
      "DesignSync",
      "Monitor",
      "NotebookEdit",
      "PowerShell",
      "PushNotification",
      "RemoteTrigger",
      "ReportFindings",
      "ScheduleWakeup",
      "SendMessage",
      "WebSearch",
      "Workflow"

    ]
  },

  "toolPermissions": {
    "defaultMode": "ask"
  }
}
